{
  "name": "spine",
  "version": "0.1.0",
  "description": "Core coordination layer and state vault for agentic systems.",
  "repository": "github.com/nathfavour/spine",
  "build": {
    "steps": [
      "mkdir -p bin",
      "CGO_ENABLED=0 go build -ldflags=\"-s -w\" -o bin/spine ./cmd/spine"
    ],
    "bin": "bin/spine",
    "toolchain": "go"
  },
  "runtime": {
    "daemon": true,
    "pulse": true
  }
}
