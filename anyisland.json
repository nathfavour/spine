{
  "name": "spine",
  "version": "0.1.0",
  "description": "Core coordination layer and state vault for agentic systems.",
  "repository": "github.com/nathfavour/spine",
  "source_dir": "~/.spine/source",
  "install_dir": "~/.local/bin",
  "build": {
    "steps": [
      "make build"
    ],
    "bin": "bin/spine",
    "toolchain": "go"
  },
  "runtime": {
    "daemon": true,
    "pulse": true
  }
}
